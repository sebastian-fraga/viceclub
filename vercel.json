{
    "cleanUrls": true,
    "trailingSlash": false,

    "redirects": [
        {
            "source": "/:path*",
            "has": [
                {
                    "type": "host",
                    "value": "viceclub.app"
                }
            ],
            "destination": "https://www.viceclub.app/:path*",
            "permanent": true
        }
    ]
}
