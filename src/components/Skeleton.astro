---
interface Props {
    variant:
        | "homeCard"
        | "checklist"
        | "artworks"
        | "mods"
        | "achievements"
        | "map"
        | "radio"
        | "cheats";
    count?: number;
    game?: string;
}

const { variant, count = 1, game } = Astro.props;
---

{
    (
        <>
            {variant === "radio" &&
                Array.from({ length: count }).map((_, index) => {
                    const isGTAV = game === "V";

                    const angle = (360 / count) * index;
                    const radius = 280;

                    return (
                        <div
                            class:list={[
                                "skeleton-base",
                                game === "V"
                                    ? "skeleton-radio-v"
                                    : "skeleton-radio",
                                game === "V" && "radio-card",
                            ]}
                            style={
                                isGTAV
                                    ? `transform:
                            rotate(${angle}deg)
                            translate(${radius}px)
                            rotate(-${angle}deg); border-radius: 50%`
                                    : ""
                            }
                            aria-hidden="true"
                        />
                    );
                })}

            {variant === "checklist" && (
                <div class="skeleton-checklist-row" aria-hidden="true">
                    <div class="skeleton-base skeleton-checkbox" />
                    <div class="skeleton-base skeleton-text" />
                </div>
            )}

            {variant === "homeCard" && (
                <div class="skeleton-card" aria-hidden="true">
                    <div class="skeleton-base skeleton-image" />
                    <div class="skeleton-base skeleton-title" />
                    <div class="skeleton-base skeleton-line" />
                </div>
            )}
        </>
    )
}

<style>
    @keyframes shimmer {
        0% {
            background-position: -1250px 0;
        }

        100% {
            background-position: 1250px 0;
        }
    }

    /* BASE */

    .skeleton-base {
        background: linear-gradient(
            90deg,
            rgba(255, 255, 255, 0.03) 25%,
            rgba(255, 255, 255, 0.08) 50%,
            rgba(255, 255, 255, 0.03) 75%
        );

        background-size: 1250px 100%;
        animation: shimmer 1.5s infinite linear;
        border-radius: 6px;
        display: block;
    }

    /* RADIO */

    .skeleton-radio {
        width: 90px;
        margin-inline: 15px;
        height: 90px;
    }


    /* CHECKLIST */

    .skeleton-checklist-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 14px;
    }

    .skeleton-checkbox {
        width: 22px;
        height: 22px;
        border-radius: 4px;
        flex-shrink: 0;
    }

    .skeleton-text {
        height: 16px;
        width: 100%;
        border-radius: 4px;
    }

    /* HOME CARD */

    .skeleton-card {
        display: flex;
        flex-direction: column;
        gap: 10px;
        padding: 15px;
    }

    .skeleton-image {
        width: 100%;
        height: 150px;
        border-radius: 12px;
    }

    .skeleton-title {
        width: 60%;
        height: 20px;
    }

    .skeleton-line {
        width: 100%;
        height: 14px;
    }
</style>
