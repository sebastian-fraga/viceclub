---
interface Props {
  game?: string;
  isIndex?: boolean;
}

const { game = "", isIndex = false } = Astro.props;

const navGames = [
  { id: "VI", name: "GTA VI" },
  { id: "V", name: "GTA V" },
  { id: "IV", name: "GTA IV" },
  { id: "VCS", name: "GTA Vice City Stories" },
  { id: "LCS", name: "GTA Liberty City Stories" },
  { id: "SA", name: "GTA San Andreas" },
  { id: "VC", name: "GTA Vice City" },
  { id: "III", name: "GTA III" }
];
---
<footer style={isIndex ? "opacity: 0; transition: opacity 0.8s ease" : undefined}>
    <div class="footer-left">
        <div class="footer-logo">
            <a href="/">
                <img
                    src="/assets/images/app/logo.webp"
                    alt="Logo de Vice Club"
                    loading="lazy"
                />
                <p>VICE CLUB</p>
            </a>
        </div>
        <div class="footer-left-text">
            <p>
                El sitio web ideal si eres un fanático de la saga Grand
                Theft Auto.
            </p>
        </div>
        <div class="footer-icons">
            <a href="https://x.com/ViceClubApp">
                <img
                    src="/assets/images/icons/social/x.webp"
                    alt="Logo de X"
                    loading="lazy"
                />
            </a>
            <a href="https://github.com/sebastian-fraga/viceclub">
                <img
                    src="/assets/images/icons/social/github.webp"
                    alt="Logo de GitHub"
                    loading="lazy"
                />
            </a>
        </div>
    </div>
    <div class="footer-center">
        <div class="footer-title">
            <span class="material-symbols-rounded">explore</span>
            <p>NAVEGACIÓN</p>
        </div>
        <ul>
            {navGames.map((g) => (
                <li>
                    <a class={game === g.id ? "active" : undefined} href={`/${g.id}/inicio`}>
                        {g.name}
                    </a>
                </li>
            ))}
        </ul>
    </div>
    <div class="footer-right">
        <div class="footer-title">
            <span class="material-symbols-rounded">policy</span>
            <p>AVISO LEGAL</p>
        </div>
        <div class="footer-text">
            <span>Vice Club es un sitio de fans independiente</span>
            <span style="font-weight: 800"
                >No está afiliado con Rockstar Games ni con Take-Two
                Interactive.</span
            >
            <span>Las marcas GTA y Grand Theft Auto son marcas
                registradas de sus respectivos propietarios</span>
        </div>
    </div>
    <div class="footer-bottom">
        <div class="footer-copyright">
            <p>
                •ᴗ•
                <span>
                    {new Date().getFullYear()}
                </span>
                - Vice Club
            </p>
        </div>
        <div class="footer-button">
            <a href="#top">
                <span class="material-symbols-rounded">
                    keyboard_double_arrow_up
                </span>
                <span>VOLVER ARRIBA</span>
            </a>
        </div>
    </div>
</footer>
