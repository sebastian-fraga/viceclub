---
import "../styles/pages/index.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Loader from "../components/Loader.astro";

import PlayStation_5 from "../components/icons/PlayStation_5.astro";
import XboxSeries from "../components/icons/XboxSeries.astro";
import PlayStation5 from "../components/icons/PlayStation_5.astro";
---

<BaseLayout
    title="Vice Club | La página definitiva de la saga GTA"
    description="Guías completas de GTA, checklists para el 100%, mapas interactivos, mods, trucos y radios de GTA San Andreas, GTA 5, GTA 6 y más"
    canonical="https://www.viceclub.app/"
    bodyClass="index"
    isIndex={true}
>
    <Loader slot="loader" />

    <main
        class="block"
        id="container"
        style="opacity: 0; transition: opacity 0.8s ease"
    >
        <section class="welcome-wrapper">
            <h1 class="welcome-title" id="title" data-i18n="index.welcome">
                BIENVENIDO A VICE CLUB
            </h1>
            <div class="fotd-container">
                <div class="fotd-header">
                    <h2 data-i18n="index.fotd.title">DATO DEL DÍA</h2>
                    <img src="" alt="" />
                </div>
                <div class="fotd-image">
                    <img alt="Imagen del dato del día" />
                </div>
                <div class="fotd-description">
                    <p></p>
                </div>
                <div class="fotd-buttons"></div>
            </div>
            <div class="welcome-text">
                <p class="index-text" data-i18n="index.text.first">
                    Aquí podrás encontrar todo lo que buscas sobre los juegos de
                    la saga GTA: <span>Información</span>,
                    <span>noticias</span>, todos los <span>trucos</span> y
                    <span>mods indispensables</span> para tu partida,
                    <span>mapas interactivos</span> para completar los coleccionables
                    mientras juegas, todas las
                    <span>radios</span> disponibles para escuchar en tu día a día,
                    curiosidades y mucho más
                </p>
                <p class="index-text" data-i18n="index.text.second">
                    ¡Actualizaciones de contenido <span>cada semana</span>! No
                    dudes en visitarnos a menudo y agregar la página a favoritos
                    (o incluso instalarla como una aplicación independiente!)
                </p>
            </div>
        </section>

        <section id="countdown-section" class="countdown-wrapper">
            <div class="countdown-header">
                <h2 data-i18n="index.countdown.title">
                    Lanzamiento de Grand Theft Auto VI
                </h2>
            </div>

            <div id="countdown">
                <div class="time-box">
                    <span id="days">0</span>
                    <p data-i18n="index.countdown.days">DÍAS</p>
                    <div class="time-separator">:</div>
                </div>

                <div class="time-box">
                    <span id="hours">0</span>
                    <p data-i18n="index.countdown.hours">HORAS</p>
                    <div class="time-separator">:</div>
                </div>

                <div class="time-box">
                    <span id="minutes">0</span>
                    <p data-i18n="index.countdown.minutes">MINUTOS</p>
                    <div class="time-separator">:</div>
                </div>

                <div class="time-box">
                    <span id="seconds">0</span>
                    <p data-i18n="index.countdown.seconds">SEGUNDOS</p>
                </div>
            </div>
        </section>

        <section id="countdown-finished" class="hidden">
            <div class="countdown-header">
                <h2 data-i18n="index.countdown.finished.title">
                    ¡Grand Theft Auto VI ya disponible!
                </h2>
            </div>
            <div class="countdown-buttons">
                <a
                    href="https://www.playstation.com/games/grand-theft-auto-vi/"
                >
                    <PlayStation5 />
                </a>
                <a
                    href="https://www.xbox.com/games/store/grand-theft-auto-vi/9nl3wwnzlzzn"
                >
                    <XboxSeries />
                </a>
            </div>
        </section>

        <section class="logo-carousel">
            <h2 data-i18n="index.carousel.cta">Explora Vice Club</h2>
            <div class="carousel-wrapper">
                <a href="/III/inicio">
                    <img
                        src="/assets/images/icons/games/logos/III.webp"
                        alt="Logo de GTA 3"
                        loading="lazy"
                    />
                    <span>GTA III</span>
                </a>
                <a href="/VC/inicio">
                    <img
                        src="/assets/images/icons/games/logos/VC.webp"
                        alt="Logo de GTA Vice City"
                        loading="lazy"
                    />
                    <span>GTA Vice City</span>
                </a>
                <a href="/SA/inicio">
                    <img
                        src="/assets/images/icons/games/logos/SA.webp"
                        alt="Logo de GTA San Andreas"
                        loading="lazy"
                    />
                    <span>GTA San Andreas</span>
                </a>
                <a href="/LCS/inicio">
                    <img
                        src="/assets/images/icons/games/logos/LCS.webp"
                        alt="Logo de GTA Liberty City Stories"
                        loading="lazy"
                    />
                    <span>GTA Liberty City Stories</span>
                </a>
                <a href="/VCS/inicio">
                    <img
                        src="/assets/images/icons/games/logos/VCS.webp"
                        alt="Logo de GTA Vice City Stories"
                        loading="lazy"
                    />
                    <span>GTA Vice City Stories</span>
                </a>
                <a href="/IV/inicio">
                    <img
                        src="/assets/images/icons/games/logos/IV.webp"
                        alt="Logo de GTA 4"
                        loading="lazy"
                    />
                    <span>GTA IV</span>
                </a>
                <a href="/V/inicio">
                    <img
                        src="/assets/images/icons/games/logos/V.webp"
                        alt="Logo de GTA 5"
                        loading="lazy"
                    />
                    <span>GTA V</span>
                </a>
                <a href="/VI/inicio">
                    <img
                        src="/assets/images/icons/games/logos/VI.webp"
                        alt="Logo de GTA 6"
                        loading="lazy"
                    />
                    <span>GTA VI</span>
                </a>
            </div>
        </section>

        <section class="news">
            <h2 data-i18n="index.news.title">ÚLTIMAS NOTICIAS</h2>
            <div id="newsContainer"></div>
            <button
                id="loadNews"
                aria-label="Cargar más noticias"
                data-i18n="index.news.button"
            >
                CARGAR MÁS NOTICIAS
                <span class="material-symbols-rounded">expand_more</span>
            </button>
        </section>

        <section class="faq">
            <details>
                <summary data-i18n="index.faq.title"
                    >PREGUNTAS FRECUENTES</summary
                >
                <h3 data-i18n="index.faq.section.first.title">
                    <span class="material-symbols-rounded">beach_access</span
                    >Sobre Vice Club
                </h3>
                <div class="faq-section">
                    <article class="faq-question">
                        <h4 data-i18n="index.faq.section.first.q1">
                            ¿Qué puedo encontrar en Vice Club?
                        </h4>
                        <p data-i18n="index.faq.section.first.a1">
                            En Vice Club encontrarás toda la información
                            relacionada a cada juego principal de la saga GTA.
                            Tendrás acceso a todos los trucos, radios, mapas
                            interactivos, mods, noticias y mucho más.
                        </p>
                    </article>

                    <article class="faq-question">
                        <h4 data-i18n="index.faq.section.first.q2">
                            ¿Cómo busco información por juego?
                        </h4>
                        <p data-i18n="index.faq.section.first.a2">
                            Muy sencillo. Simplemente tienes que tocar en el
                            menú de arriba a la derecha, y podrás elegir el
                            juego que deseas consultar. Para volver a esta
                            página principal, es tan sencillo como tocar en el
                            logo de Vice Club de arriba a la izquierda.
                        </p>
                    </article>

                    <article class="faq-question">
                        <h4 data-i18n="index.faq.section.first.q3">
                            ¿Cómo nace Vice Club?
                        </h4>
                        <p data-i18n="index.faq.section.first.a3">
                            Vice Club nace como un proyecto personal de
                            desarrollo web, el cual comencé a idearlo a
                            principios de 2025. Me pareció una buena idea para
                            poder practicar mis conocimientos en desarrollo
                            front-end mientras plasmo todo en un sitio web
                            dedicado a una de mis sagas favoritas de
                            videojuegos.
                        </p>
                    </article>
                    <article class="faq-question">
                        <h4 data-i18n="index.faq.section.first.q4">
                            ¿Con qué frecuencia se actualiza el contenido?
                        </h4>
                        <p data-i18n="index.faq.section.first.a4">
                            Prometo traer más información y contenido todas las
                            semanas hasta terminar con mis
                            <a
                                href="https://github.com/sebastian-fraga/viceclub/issues"
                                referrerpolicy="no-referrer">tareas</a
                            >.
                        </p>
                    </article>
                    <article class="faq-question">
                        <h4 data-i18n="index.faq.section.first.q5">
                            ¿Puedo sugerir contenido, reportar algún error o
                            simplemente colaborar en el desarrollo?
                        </h4>
                        <p data-i18n="index.faq.section.first.a5">
                            ¡Por supuesto! Vice Club es de código abierto y su
                            repositorio puede encontrarse en
                            <a
                                href="https://github.com/sebastian-fraga/viceclub"
                                referrerpolicy="no-referrer">GitHub</a
                            >.
                        </p>
                    </article>
                </div>
                <h3 data-i18n="index.faq.section.second.title">
                    <span class="material-symbols-rounded">person</span>
                    Sobre mí
                </h3>
                <div class="faq-section">
                    <article class="faq-question">
                        <h4 data-i18n="index.faq.section.second.q1">
                            ¿Quién soy?
                        </h4>
                        <p data-i18n="index.faq.section.second.a1">
                            Mi nombre es Sebastián. Soy un desarrollador web
                            front-end nacido en Argentina y fanático de la saga
                            GTA.
                        </p>
                    </article>

                    <article class="faq-question">
                        <h4 data-i18n="index.faq.section.second.q2">
                            ¿Cómo puedo contactarte?
                        </h4>
                        <p data-i18n="index.faq.section.second.a2">
                            Puedes enviarme un
                            <a href="mailto:fragasebastian1@gmail.com"
                                >correo electrónico</a
                            >
                            o contactarme por
                            <a
                                href="https://github.com/sebastian-fraga"
                                referrerpolicy="no-referrer">GitHub</a
                            >.
                        </p>
                    </article>

                    <article class="faq-question">
                        <h4 data-i18n="index.faq.section.second.q3">
                            ¿Juego favorito de la saga?
                        </h4>
                        <p data-i18n="index.faq.section.second.a3">
                            Sin ningún tipo de dudas, San Andreas. Por todo lo
                            que significó y sigue haciendo a más de 20 años
                            desde su salida. Menciones honoríficas a la mejor
                            historia de la saga (GTA 4) y a la mejor
                            ambientación (GTA Vice City)
                        </p>
                    </article>
                </div>
            </details>
        </section>

        <section class="support">
            <p data-i18n="index.support">
                Vice Club es un proyecto 100% gratuito, hecho con mucho amor por
                toda la saga. Si te gusta y deseas apoyar el desarrollo, podés
                invitarme un café:
            </p>
            <div class="support-buttons">
                <article>
                    <a
                        href="https://cafecito.app/sebastianfraga"
                        rel="noopener"
                        target="_blank"
                        ><img
                            srcset="
                                https://cdn.cafecito.app/imgs/buttons/button_3.png       1x,
                                https://cdn.cafecito.app/imgs/buttons/button_3_2x.png    2x,
                                https://cdn.cafecito.app/imgs/buttons/button_3_3.75x.png 3.75x
                            "
                            src="https://cdn.cafecito.app/imgs/buttons/button_3.png"
                            alt="Invitame un café en cafecito.app"
                        /></a
                    >
                </article>
                <article>
                    <script
                        type="text/javascript"
                        src="https://storage.ko-fi.com/cdn/widget/Widget_2.js"
                        is:inline></script>
                    <script type="text/javascript" is:inline>
                        kofiwidget2.init("Ko-fi", "#72a4f2", "T6T71RM9WX");
                        kofiwidget2.draw();
                    </script>
                </article>
            </div>
        </section>
    </main>

    <dialog id="imageOverlay" slot="overlay">
        <button
            class="material-symbols-rounded close-btn"
            id="closeBtn"
            aria-label="Cerrar"
        >
            close_small
        </button>
        <figure>
            <div class="image-wrapper">
                <img src="" alt="Imagen ampliada" id="overlayImg" />
            </div>
            <figcaption id="overlayFooterText"></figcaption>
        </figure>
    </dialog>

    <fragment slot="scripts">
        <!-- Loader -->
        <script is:inline>
            window.addEventListener("load", () => {
                const isLocalhost = location.hostname === "localhost";

                const loader = document.getElementById("loader");
                const content = document.getElementById("container");
                const header = document.querySelector("header");
                const footer = document.querySelector("footer");

                // debug
                if (isLocalhost) {
                    loader?.remove();

                    document.body.style.overflow = "auto";

                    content.style.display = "flex";
                    header.style.display = "flex";

                    content.style.opacity = "1";
                    header.style.opacity = "1";
                    footer.style.opacity = "1";

                    return;
                }

                // prod
                setTimeout(() => {
                    loader.classList.add("hidden");
                    document.body.style.overflow = "auto";

                    content.style.display = "flex";
                    header.style.display = "flex";

                    requestAnimationFrame(() => {
                        content.style.opacity = "1";
                        header.style.opacity = "1";
                        footer.style.opacity = "1";
                    });

                    window.dispatchEvent(new CustomEvent("newsReady"));

                    setTimeout(() => loader.remove(), 1200);
                }, 1400);
            });
        </script>

        <!--Facts-->
        <script is:inline src="/assets/scripts/facts.js"></script>

        <!--Countdown-->
        <script is:inline src="/assets/scripts/countdown.js"></script>

        <!--News-->
        <script is:inline src="/assets/scripts/news.js"></script>

        <!--Overlay-->
        <script is:inline src="/assets/scripts/overlay.js"></script>

        <!-- Service Worker -->
        <script>
            if ("serviceWorker" in navigator) {
                console.log("Service Worker soportado");

                navigator.serviceWorker
                    .register("/sw.js")
                    .then(() => console.log("Service Worker registrado"))
                    .catch((err) =>
                        console.error("Error de Service Worker", err),
                    );
            }
        </script>
    </fragment>
</BaseLayout>
