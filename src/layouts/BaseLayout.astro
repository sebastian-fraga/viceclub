---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import RightMenu from "../components/RightMenu.astro";

interface Props {
    title: string;
    description: string;
    canonical: string;
    bodyClass?: string;
    dataGame?: string;
    game?: string;
    section?: string;
    isIndex?: boolean;
}

const {
    title,
    description,
    canonical,
    bodyClass = "",
    dataGame,
    game = "",
    section = "",
    isIndex = false,
} = Astro.props;
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <link rel="icon" href="/favicon.ico" type="image/x-icon" />
        <link rel="icon" href="/favicon.png" type="image/png" sizes="96x96" />

        <link rel="stylesheet" href="/assets/styles/styles.css" />
        {
            game && (
                <link
                    rel="stylesheet"
                    href={`/assets/styles/styles_${game}.css`}
                />
            )
        }
        <link rel="manifest" href="/manifest.json" />
        <link rel="canonical" href={canonical} />
        <link
            rel="stylesheet"
            href="https://fonts.googleapis.com/css2?family=Material+Symbols+Rounded:opsz,wght,FILL,GRAD@24,400,1,0"
        />

        <meta name="description" content={description} />

        <meta property="og:site_name" content="Vice Club" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta
            property="og:image"
            content="https://www.viceclub.app/assets/images/main/og.webp"
        />
        <meta property="og:url" content={canonical} />
        <meta property="og:type" content={isIndex ? "website" : "article"} />

        <title>{title}</title>
        <script type="application/ld+json">
            {
                "@context": "https://schema.org",
                "@type": "WebSite",
                "name": "Vice Club",
                "url": "https://www.viceclub.app"
            }
        </script>
        <slot name="head" />
    </head>

    <body class={bodyClass} data-game={dataGame} id="top">
        <slot name="loader" />
        <Header isIndex={isIndex} />

        <slot />

        <Footer game={game} isIndex={isIndex} />
        <RightMenu isIndex={isIndex} game={game} section={section} />
        <slot name="overlay" />

        <!-- Language Selector -->
        <script is:inline src="/assets/scripts/language-selector.js"></script>
        <!-- Right Content Sidebar -->
        <script is:inline src="/assets/scripts/right-menu.js"></script>

        <slot name="scripts" />
    </body>
</html>
